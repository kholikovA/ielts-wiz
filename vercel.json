{
  "git": {
    "deploymentEnabled": {
      "cloudflare/workers-autoconfig": false
    }
  },
  "headers": [
    {
      "source": "/((?!static/).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
